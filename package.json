{
  "name": "openlog",
  "version": "0.1.0",
  "private": true,
  "description": "Open log console for mobile debugging",
  "author": "openLog Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uaio/openLog.git"
  },
  "homepage": "https://github.com/uaio/openLog",
  "bugs": {
    "url": "https://github.com/uaio/openLog/issues"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint packages/types/src/ packages/sdk/src/ packages/server/src/ packages/mcp/src/ packages/cli/src/ packages/web/src/",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\"",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "start": "node packages/server/bin/openlog",
    "demo": "pnpm --filter @openlog/demo dev"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}