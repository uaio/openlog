{
  "name": "@openlog/sdk",
  "version": "0.1.1",
  "description": "Mobile H5 SDK for openLog — real-time console, network, storage, DOM, performance collection",
  "keywords": ["openlog", "sdk", "mobile-debugging", "h5", "console", "network", "performance", "eruda"],
  "author": "openLog Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uaio/openLog.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/uaio/openLog/tree/main/packages/sdk",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build --config build/vite.config.ts",
    "test": "vitest"
  },
  "devDependencies": {
    "eruda": "workspace:*",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.6.0",
    "web-vitals": "^5.2.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  }
}
