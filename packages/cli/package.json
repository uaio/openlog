{
  "name": "@openlog/cli",
  "version": "0.1.1",
  "description": "CLI for openLog — start server, configure AI tools, one-command setup",
  "keywords": ["openlog", "cli", "mobile-debugging", "mcp", "claude", "cursor", "devtools"],
  "author": "openLog Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uaio/openLog.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/uaio/openLog/tree/main/packages/cli",
  "type": "module",
  "bin": {
    "openlog": "./bin/openlog.js"
  },
  "files": [
    "bin",
    "dist",
    "public"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist public",
    "prebuild": "npm run clean",
    "build": "tsc && npm run copy-web",
    "copy-web": "node scripts/copy-web.cjs",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@openlog/mcp": "workspace:*",
    "@openlog/server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
