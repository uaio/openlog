{
  "name": "@openlog/mcp",
  "version": "0.1.1",
  "description": "MCP (Model Context Protocol) server for openLog — 30+ AI-callable debugging tools",
  "keywords": ["openlog", "mcp", "ai", "claude", "cursor", "model-context-protocol", "debugging"],
  "author": "openLog Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uaio/openLog.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/uaio/openLog/tree/main/packages/mcp",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openlog-mcp": "./bin/openlog-mcp"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "build": "npm run clean && tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openlog/server": "workspace:*",
    "@openlog/types": "workspace:*",
    "open": "^10.0.0",
    "ws": "^8.16.0"
  },
  "peerDependencies": {
    "zod": "^3.25.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "vitest": "^1.6.0",
    "zod": "^3.25.0"
  }
}
