{
  "name": "@openlog/server",
  "version": "0.1.0",
  "description": "Node.js WebSocket + REST API server for openLog — real-time device communication hub",
  "keywords": [
    "openlog",
    "server",
    "websocket",
    "rest-api",
    "mobile-debugging",
    "real-time"
  ],
  "author": "openLog Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uaio/openLog.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/uaio/openLog/tree/main/packages/server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./cli/init": {
      "types": "./dist/cli/init.d.ts",
      "import": "./dist/cli/init.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "build": "npm run clean && tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@openlog/types": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^4.18.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/ws": "^8.5.0",
    "vitest": "^1.6.0"
  }
}
