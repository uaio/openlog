{
  "name": "@openlog/types",
  "version": "0.1.1",
  "description": "Shared TypeScript type definitions for openLog (Envelope format, events, protocol)",
  "keywords": ["openlog", "types", "typescript", "mobile-debugging", "logging"],
  "author": "openLog Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uaio/openLog.git",
    "directory": "packages/types"
  },
  "homepage": "https://github.com/uaio/openLog/tree/main/packages/types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
